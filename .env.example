# Servidor
NODE_ENV=production
PORT=4000
APP_API_PREFIX=/api
APP_TIMEZONE=America/Sao_Paulo

# PostgreSQL (substitua pelos valores do seu servidor)
DB_HOST=69.62.99.122
DB_PORT=4213
DB_NAME=myboard
DB_USER=myboard
DB_PASSWORD=myboard
DB_MAINTENANCE_DATABASE=postgres
DB_LOGGING=false

# Segurança
CREDENTIALS_ENCRYPTION_KEY=change-me-to-a-random-32-char-secret-key
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=1h
APP_URL=http://localhost:3000

# E-mail (opcional — sem SMTP, o token de reset aparece no log do servidor)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyBoard <noreply@myboard.app>

# Admin inicial (criado automaticamente no primeiro start)
SEED_ADMIN_EMAIL=patrickgsiqueira@hotmail.com
SEED_ADMIN_PASSWORD=patrick123
SEED_ADMIN_NAME=Patrick Gomes

# Uploads
UPLOAD_DIR=./uploads
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_MAX_SIZE_MB=25

# Socket.io
SOCKET_CORS_ORIGIN=*
SOCKET_PATH=/socket.io

# IA (Bordie + RAG) — chaves configuradas em Configurações → IA no app
# OPENROUTER_* abaixo são legado/opcionais; não são mais necessários se usar settings por tenant
OPENROUTER_EMBEDDING_DIMENSIONS=1536

# Evolution API (WhatsApp)
EVOLUTION_API_BASE_URL=https://geral-myboard-evolution.r954jc.easypanel.host
EVOLUTION_API_KEY=
WHATSAPP_WEBHOOK_SECRET=

# Chatwoot (opcional — espelho/backup de ingestão)
CHATWOOT_BASE_URL=https://geral-myboard-chatwoot.r954jc.easypanel.host
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_API_TOKEN=
